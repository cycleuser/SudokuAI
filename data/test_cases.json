{
  "test_suite": "SudokuAI Test Suite",
  "version": "1.0",
  "test_cases": [
    {
      "id": "TC001",
      "name": "Generate easy puzzle",
      "category": "functional",
      "priority": "high",
      "input": {"difficulty": "easy"},
      "expected_output": {"success": true, "clues_range": [36, 45]}
    },
    {
      "id": "TC002",
      "name": "Generate medium puzzle",
      "category": "functional",
      "priority": "high",
      "input": {"difficulty": "medium"},
      "expected_output": {"success": true, "clues_range": [27, 35]}
    },
    {
      "id": "TC003",
      "name": "Solve valid puzzle",
      "category": "functional",
      "priority": "high",
      "input": {
        "puzzle": [[5,3,0,0,7,0,0,0,0],[6,0,0,1,9,5,0,0,0],[0,9,8,0,0,0,0,6,0],[8,0,0,0,6,0,0,0,3],[4,0,0,8,0,3,0,0,1],[7,0,0,0,2,0,0,0,6],[0,6,0,0,0,0,2,8,0],[0,0,0,4,1,9,0,0,5],[0,0,0,0,8,0,0,7,9]]
      },
      "expected_output": {"success": true}
    },
    {
      "id": "TC004",
      "name": "Validate correct solution",
      "category": "functional",
      "priority": "high",
      "input": {
        "solution": [[5,3,4,6,7,8,9,1,2],[6,7,2,1,9,5,3,4,8],[1,9,8,3,4,2,5,6,7],[8,5,9,7,6,1,4,2,3],[4,2,6,8,5,3,7,9,1],[7,1,3,9,2,4,8,5,6],[9,6,1,5,3,7,2,8,4],[2,8,7,4,1,9,6,3,5],[3,4,5,2,8,6,1,7,9]]
      },
      "expected_output": {"success": true, "is_valid": true}
    },
    {
      "id": "TC005",
      "name": "Validate incorrect solution",
      "category": "functional",
      "priority": "high",
      "input": {
        "solution": [[5,5,4,6,7,8,9,1,2],[6,7,2,1,9,5,3,4,8],[1,9,8,3,4,2,5,6,7],[8,5,9,7,6,1,4,2,3],[4,2,6,8,5,3,7,9,1],[7,1,3,9,2,4,8,5,6],[9,6,1,5,3,7,2,8,4],[2,8,7,4,1,9,6,3,5],[3,4,5,2,8,6,1,7,9]]
      },
      "expected_output": {"success": true, "is_valid": false}
    }
  ]
}